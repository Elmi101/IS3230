@model ClubBAIST.Models.Domain.TeeTimeReservation

@{
    ViewData["Title"] = "Cancel Reservation";
    var dateStr = Model.Slot.TeeSheet?.SheetDate.ToString("yyyy-MM-dd") ?? DateTime.Today.ToString("yyyy-MM-dd");
}

<div class="page-header">
    <h2>Cancel Reservation</h2>
    <p class="page-subtitle">
        @DateTime.Today.Add(Model.Slot.SlotTime).ToString("h:mm tt") —
        @Model.Slot.TeeSheet?.SheetDate.ToString("dddd, MMMM dd, yyyy")
    </p>
</div>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger mb-3">@TempData["Error"]</div>
}

<div class="panel" style="max-width:600px">
    <div class="panel-title">Reservation Details</div>

    <table class="baist-table" style="margin-bottom:1.5rem">
        <tr>
            <td style="color:#999;width:140px">Booked By</td>
            <td><strong>@Model.BookedBy?.FullName</strong></td>
        </tr>
        <tr>
            <td style="color:#999">Tee Time</td>
            <td>@DateTime.Today.Add(Model.Slot.SlotTime).ToString("h:mm tt")</td>
        </tr>
        <tr>
            <td style="color:#999">Date</td>
            <td>@Model.Slot.TeeSheet?.SheetDate.ToString("MMMM dd, yyyy")</td>
        </tr>
        <tr>
            <td style="color:#999">Players</td>
            <td>@Model.NumberOfPlayers</td>
        </tr>
        <tr>
            <td style="color:#999">Foursome</td>
            <td>
                @foreach (var p in Model.Players)
                {
                    <span class="status-pill status-booked" style="margin-right:4px">
                        @(p.Member?.FullName ?? p.GuestName ?? "Guest")
                    </span>
                }
            </td>
        </tr>
    </table>

    <div class="alert alert-warning mb-3">
        Cancelling this reservation will release the slot for other members.
        Per club rules, it is the member's responsibility to cancel if unable to attend.
    </div>

    <form method="post" action="/Reservation/CancelConfirmed">
        @Html.AntiForgeryToken()
        <input type="hidden" name="reservationId" value="@Model.ReservationId" />

        <div class="mb-4" style="max-width:250px">
            <label class="form-label">Your Member Number</label>
            <input type="text" name="cancelledByMemberNumber"
                   class="form-control" placeholder="e.g. M001" />
        </div>

        <div style="display:flex;gap:0.75rem">
            <button type="submit" class="btn-action btn-action-danger" style="padding:10px 28px">
                Confirm Cancellation
            </button>
            <a href="/TeeSheet/ViewSheet?date=@dateStr"
               class="btn-action btn-action-outline" style="padding:10px 28px">
                Go Back
            </a>
        </div>
    </form>
</div>