@model ClubBAIST.Models.ViewModels.ApplicationViewModel

@{
    ViewData["Title"] = "Membership Application";
}

<div class="page-header">
    <h2>Membership Application</h2>
    <p class="page-subtitle">Club BAIST Private Golf Club</p>
</div>

@if (Model.ErrorMessage != null)
{
    <div class="alert alert-danger mb-3">@Model.ErrorMessage</div>
}

<form method="post" action="/Application/Apply">
    @Html.AntiForgeryToken()

    <div class="panel">
        <div class="panel-title">Personal Information</div>
        <div class="row">
            <div class="col-md-4 mb-3">
                <label class="form-label">First Name *</label>
                <input type="text" name="FirstName" class="form-control"
                       value="@Model.FirstName" />
            </div>
            <div class="col-md-4 mb-3">
                <label class="form-label">Last Name *</label>
                <input type="text" name="LastName" class="form-control"
                       value="@Model.LastName" />
            </div>
            <div class="col-md-4 mb-3">
                <label class="form-label">Date of Birth</label>
                <input type="date" name="DateOfBirth" class="form-control"
                       value="@Model.DateOfBirth?.ToString("yyyy-MM-dd")" />
            </div>
        </div>
        <div class="row">
            <div class="col-md-6 mb-3">
                <label class="form-label">Address *</label>
                <input type="text" name="Address" class="form-control"
                       value="@Model.Address" />
            </div>
            <div class="col-md-3 mb-3">
                <label class="form-label">Postal Code</label>
                <input type="text" name="PostalCode" class="form-control"
                       value="@Model.PostalCode" />
            </div>
        </div>
        <div class="row">
            <div class="col-md-3 mb-3">
                <label class="form-label">Phone *</label>
                <input type="text" name="Phone" class="form-control"
                       value="@Model.Phone" />
            </div>
            <div class="col-md-3 mb-3">
                <label class="form-label">Alternate Phone</label>
                <input type="text" name="AlternatePhone" class="form-control"
                       value="@Model.AlternatePhone" />
            </div>
            <div class="col-md-4 mb-3">
                <label class="form-label">Email</label>
                <input type="email" name="Email" class="form-control"
                       value="@Model.Email" />
                <div class="form-text">Providing email allows monthly statements via email</div>
            </div>
        </div>
    </div>

    <div class="panel">
        <div class="panel-title">Employment Information</div>
        <div class="row">
            <div class="col-md-4 mb-3">
                <label class="form-label">Occupation</label>
                <input type="text" name="Occupation" class="form-control"
                       value="@Model.Occupation" />
            </div>
            <div class="col-md-4 mb-3">
                <label class="form-label">Company Name</label>
                <input type="text" name="CompanyName" class="form-control"
                       value="@Model.CompanyName" />
            </div>
            <div class="col-md-4 mb-3">
                <label class="form-label">Company Phone</label>
                <input type="text" name="CompanyPhone" class="form-control"
                       value="@Model.CompanyPhone" />
            </div>
        </div>
        <div class="row">
            <div class="col-md-6 mb-3">
                <label class="form-label">Company Address</label>
                <input type="text" name="CompanyAddress" class="form-control"
                       value="@Model.CompanyAddress" />
            </div>
            <div class="col-md-3 mb-3">
                <label class="form-label">Company Postal Code</label>
                <input type="text" name="CompanyPostalCode" class="form-control"
                       value="@Model.CompanyPostalCode" />
            </div>
        </div>
    </div>

    <div class="panel">
        <div class="panel-title">Desired Membership</div>
        <div class="col-md-6 mb-3">
            <label class="form-label">Membership Type *</label>
            <select name="DesiredTypeId" class="form-select">
                <option value="">— Select a type —</option>
                @foreach (var type in Model.MembershipTypes)
                {
                    <option value="@type.TypeId"
                            @(Model.DesiredTypeId == type.TypeId ? "selected" : "")>
                        @type.DisplayName
                    </option>
                }
            </select>
        </div>

        <div class="alert alert-info mt-3">
            <strong>Fee Summary</strong><br />
            Share Purchase: $1,000 (one-time) &nbsp;·&nbsp;
            Entrance Fee: $10,000 (4 × $2,500 installments)<br />
            Annual fee due April 1 10% penalty on overdue balances &nbsp;·&nbsp;
            Gold members: minimum $500/yr food & beverage charge
        </div>
    </div>

    <div class="panel">
        <div class="panel-title">Sponsoring Members</div>
        <p style="font-size:0.82rem;color:#999;margin-bottom:1.5rem">
            Two existing Shareholder members must sponsor your application.
            Sponsors must have been members for at least 5 years and be in good standing.
        </p>
        <div class="row">
            <div class="col-md-3 mb-3">
                <label class="form-label">Sponsor 1 Member # *</label>
                <input type="text" name="Sponsor1MemberNumber" class="form-control"
                       placeholder="e.g. M001" value="@Model.Sponsor1MemberNumber" />
            </div>
            <div class="col-md-4 mb-3">
                <label class="form-label">Sponsor 1 Signature</label>
                <input type="text" name="Sponsor1Signature" class="form-control"
                       placeholder="Type full name as signature"
                       value="@Model.Sponsor1Signature" />
            </div>
        </div>
        <div class="row">
            <div class="col-md-3 mb-3">
                <label class="form-label">Sponsor 2 Member # *</label>
                <input type="text" name="Sponsor2MemberNumber" class="form-control"
                       placeholder="e.g. M002" value="@Model.Sponsor2MemberNumber" />
            </div>
            <div class="col-md-4 mb-3">
                <label class="form-label">Sponsor 2 Signature</label>
                <input type="text" name="Sponsor2Signature" class="form-control"
                       placeholder="Type full name as signature"
                       value="@Model.Sponsor2Signature" />
            </div>
        </div>
    </div>

    <div class="panel">
        <p style="font-size:0.78rem;color:#aaa;line-height:1.8;margin-bottom:1.5rem">
            <strong>PRIVACY:</strong> The information you provide is requested strictly to update
            our membership data and roster. It will not be used for any other purpose except
            with your written permission.
        </p>
        <div style="display:flex;gap:0.75rem">
            <button type="submit" class="btn-action btn-action-dark" style="padding:12px 36px">
                Submit Application
            </button>
            <a href="/Home/Index" class="btn-action btn-action-outline" style="padding:12px 36px">
                Cancel
            </a>
        </div>
    </div>
</form>