@model ClubBAIST.Models.ViewModels.ReviewApplicationViewModel

@{
    ViewData["Title"] = "Review Application";
}

<div class="page-header">
    <h2>Application #@Model.ApplicationId</h2>
    <p class="page-subtitle">@Model.ApplicantName — @Model.CurrentStatus</p>
</div>

<div class="row">
    <div class="col-md-6">
        <div class="panel">
            <div class="panel-title">Applicant Details</div>
            <table class="baist-table">
                <tr><td style="color:#999;width:130px">Name</td><td><strong>@Model.ApplicantName</strong></td></tr>
                <tr><td style="color:#999">Email</td><td>@Model.Email</td></tr>
                <tr><td style="color:#999">Phone</td><td>@Model.Phone</td></tr>
                <tr><td style="color:#999">Date of Birth</td><td>@Model.DateOfBirth?.ToString("MMMM dd, yyyy")</td></tr>
                <tr><td style="color:#999">Address</td><td>@Model.Address</td></tr>
                <tr><td style="color:#999">Occupation</td><td>@Model.Occupation</td></tr>
                <tr><td style="color:#999">Desired Type</td><td>@Model.DesiredTypeName</td></tr>
                <tr><td style="color:#999">Sponsor 1</td><td>@Model.Sponsor1Name</td></tr>
                <tr><td style="color:#999">Sponsor 2</td><td>@Model.Sponsor2Name</td></tr>
                <tr><td style="color:#999">Submitted</td><td>@Model.SubmittedDate.ToString("MMMM dd, yyyy")</td></tr>
            </table>
        </div>
    </div>

    <div class="col-md-6">
        <div class="panel">
            <div class="panel-title">Committee Decision</div>

            <form method="post" action="/Application/ReviewDetail">
                @Html.AntiForgeryToken()
                <input type="hidden" name="ApplicationId" value="@Model.ApplicationId" />
                <input type="hidden" name="ApplicantName" value="@Model.ApplicantName" />
                <input type="hidden" name="Sponsor1Name" value="@Model.Sponsor1Name" />
                <input type="hidden" name="Sponsor2Name" value="@Model.Sponsor2Name" />
                <input type="hidden" name="DesiredTypeName" value="@Model.DesiredTypeName" />
                <input type="hidden" name="CurrentStatus" value="@Model.CurrentStatus" />
                <input type="hidden" name="SubmittedDate" value="@Model.SubmittedDate" />

                <div class="mb-3">
                    <label class="form-label">Decision</label>
                    <select name="NewStatus" class="form-select">
                        <option value="Pending" @(Model.CurrentStatus == "Pending" ? "selected" : "")>Pending</option>
                        <option value="Accepted" @(Model.CurrentStatus == "Accepted" ? "selected" : "")>Accepted</option>
                        <option value="Denied" @(Model.CurrentStatus == "Denied" ? "selected" : "")>Denied</option>
                        <option value="OnHold" @(Model.CurrentStatus == "OnHold" ? "selected" : "")>On Hold</option>
                        <option value="Waitlisted" @(Model.CurrentStatus == "Waitlisted" ? "selected" : "")>Waitlisted</option>
                    </select>
                </div>

                <div class="mb-3">
                    <label class="form-label">Your Member Number</label>
                    <input type="text" name="ReviewerMemberNumber"
                           class="form-control" placeholder="e.g. M001"
                           value="@Model.ReviewerMemberNumber" />
                </div>

                <div class="mb-4">
                    <label class="form-label">Review Notes</label>
                    <textarea name="ReviewNotes" class="form-control" rows="3"
                              placeholder="Optional notes...">@Model.Notes</textarea>
                </div>

                <div class="alert alert-warning mb-3" style="font-size:0.8rem">
                    Selecting <strong>Accepted</strong> will automatically create
                    a new member account with a temporary password.
                </div>

                <div style="display:flex;gap:0.75rem">
                    <button type="submit" class="btn-action btn-action-gold" style="padding:10px 28px">
                        Save Decision
                    </button>
                    <a href="/Application/Review" class="btn-action btn-action-outline"
                       style="padding:10px 28px">
                        Back to List
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>